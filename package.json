{
  "name": "react-rhino",
  "version": "3.0.1",
  "description": "A simple global state management library for React.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "prepublishOnly": "npm run build",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aromalanil/react-rhino.git"
  },
  "keywords": [
    "react-state",
    "state-management",
    "react-state-management",
    "react-rhino",
    "rhino"
  ],
  "author": "Aromal Anil <aromalanilkannan@gmail.com> (https://aromalanil.in)",
  "bugs": {
    "url": "https://github.com/aromalanil/react-rhino/issues"
  },
  "homepage": "https://github.com/aromalanil/react-rhino#readme",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@typescript-eslint/eslint-plugin": "^4.15.2",
    "eslint": "^7.32.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.26.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^7.0.2",
    "prettier": "^2.2.1",
    "react": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^4.2.2"
  },
  "lint-staged": {
    "src/**/*.{tsx,ts,js,jsx}": [
      "eslint src --fix",
      "prettier src --write"
    ]
  }
}
